# MongoDB Configuration
PORT=3000
MONGO_URI=your_mongodb_connection_string_here

# JWT Configuration - CHANGE THIS IN PRODUCTION
JWT_SECRET=your-super-secret-key-change-in-production-now

# OTP Configuration (in seconds)
OTP_EXPIRY=600

# WhatsApp Integration
WHATSAPP_TOKEN=your_whatsapp_bot_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here
WHATSAPP_API_VERSION=v18.0
# Optional: set a Meta-approved OTP template name for production reliability
WHATSAPP_OTP_TEMPLATE=
# Optional: expose OTP in API response only for local debugging
EXPOSE_DEV_OTP=true
# Optional: when WhatsApp send fails in development, return OTP for manual entry
ALLOW_WHATSAPP_OTP_FALLBACK=true
GOOGLE_MAPS_LINK=https://maps.google.com/?q=your_location

# Socket.io / CORS Configuration (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Comma-separated mobile numbers that get admin role (no spaces, 10 digits each)
ADMIN_PHONES=your_admin_phone_here

# Environment
NODE_ENV=development
