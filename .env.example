# Core
NODE_ENV=production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/famfood6
JWT_SECRET=replace-with-64-char-random-secret
ALLOWED_ORIGINS=https://your-frontend-domain.com

# OTP and auth
OTP_EXPIRY=600
ADMIN_PHONES=9876543210,9123456789
EXPOSE_DEV_OTP=false
ALLOW_WHATSAPP_OTP_FALLBACK=false

# WhatsApp Cloud API
WHATSAPP_API_VERSION=v18.0
WHATSAPP_TOKEN=replace-with-whatsapp-cloud-api-token
WHATSAPP_PHONE_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_COUNTRY_CODE=91
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Required in hosted production for login OTP delivery
WHATSAPP_OTP_TEMPLATE=login_otp
WHATSAPP_OTP_PARAM_KEYS=otp,expires_in_minutes

# Order templates
WHATSAPP_ORDER_PLACED_TEMPLATE=order_placed_notification
WHATSAPP_ORDER_ACCEPTED_TEMPLATE=order_accepted_notification
WHATSAPP_ORDER_REJECTED_TEMPLATE=order_rejected_notification
WHATSAPP_ORDER_READY_TEMPLATE=order_ready_notification

# Optional template parameter mapping
WHATSAPP_ORDER_PLACED_PARAM_KEYS=token_number,order_id
WHATSAPP_ORDER_ACCEPTED_PARAM_KEYS=estimated_time,location_link,token_number
WHATSAPP_ORDER_REJECTED_PARAM_KEYS=
WHATSAPP_ORDER_READY_PARAM_KEYS=delivery_pin,token_number

# Optional explicit header/body mapping per template
WHATSAPP_ORDER_PLACED_HEADER_PARAM_KEYS=
WHATSAPP_ORDER_PLACED_BODY_PARAM_KEYS=token_number,order_id
WHATSAPP_ORDER_ACCEPTED_HEADER_PARAM_KEYS=
WHATSAPP_ORDER_ACCEPTED_BODY_PARAM_KEYS=estimated_time,location_link,token_number
WHATSAPP_ORDER_REJECTED_HEADER_PARAM_KEYS=
WHATSAPP_ORDER_REJECTED_BODY_PARAM_KEYS=
WHATSAPP_ORDER_READY_HEADER_PARAM_KEYS=
WHATSAPP_ORDER_READY_BODY_PARAM_KEYS=delivery_pin,token_number

# Optional location URLs for status notifications
RESTAURANT_LOCATION_LINK=https://maps.google.com/?q=your-location
GOOGLE_MAPS_LINK=https://maps.google.com/?q=your-location
